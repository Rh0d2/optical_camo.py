import cv2
import numpy as np
import time

cap = cv2.VideoCapture(0)
time.sleep(3)
background = 0

for i in range(30):
    ret, background = cap.read()

while(cap.isOpened()):
    ret, img = cap.read()
    if not ret: break
    
    cv2.imshow("Magic Cloak", img)
    if cv2.waitKey(1) & 0xFF == ord('q'):
        break

cap.release()
cv2.destroyAllWindows()